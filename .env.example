# .env.example
# --- DATABASE SETTINGS ---
# These must match the credentials in your docker-compose.yml 'db' service
DB_USER=user
DB_PASS=password
DB_NAME=pixelcanvas
DB_HOST=db

# --- POSTGRES INTERNAL SETTINGS ---
# These are used by the official Postgres Docker image to initialize the DB
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=pixelcanvas

# --- SECURITY ---
# A long, random string used to sign JWT tokens. 
# DO NOT share the real value in production.
JWT_SECRET=replace_me_with_a_long_random_string_12345